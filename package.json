{
  "name": "github-activity-boards",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @take-this-one/web",
    "dev:worker": "npm run dev --workspace @take-this-one/worker",
    "build:web": "npm run build --workspace @take-this-one/web",
    "build:worker": "npm run build --workspace @take-this-one/worker",
    "start:worker": "npm run start --workspace @take-this-one/worker"
  }
}
